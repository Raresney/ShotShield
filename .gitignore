# ───── Rust ─────
**/target/
*.pdb
# The desktop app commits its lockfile for reproducible builds; ignore others.
Cargo.lock
!/desktop/src-tauri/Cargo.lock

# ───── Node / Tauri (desktop) ─────
node_modules/
dist/
dist-ssr/
.vite/
*.local
/desktop/src-tauri/target/
/desktop/src-tauri/gen/

# ───── Tesseract OCR runtime (desktop) ─────
# Worker + wasm core are copied from node_modules on predev/prebuild.
# Only the language model is committed — it isn't an npm package.
/desktop/public/vendor/tesseract/*
!/desktop/public/vendor/tesseract/lang/

# ───── Flutter (mobile) ─────
.dart_tool/
.flutter-plugins
.flutter-plugins-dependencies
.packages
build/
.pub-cache/
.pub/
*.iml
ios/Pods/
ios/.symlinks/
android/.gradle/
android/local.properties
*.keystore
*.jks

# ───── ML models (large, not in git) ─────
*.onnx
*.tflite
/models/

# ───── Secrets / env ─────
.env
.env.*
*.pem
*.key

# ───── Editors / OS ─────
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
desktop.ini

# ───── Misc ─────
*.log
/tmp/
/.cache/
